# =============================================================================
# PRODUCTION — set in Cloudflare Dashboard → Workers → Settings → Variables
# Do not commit real values. Use for reference only.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED FOR PILOT (CORE)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=https://aistroyka.ai
SUPABASE_SERVICE_ROLE_KEY=
NODE_ENV=production

# -----------------------------------------------------------------------------
# REQUIRED FOR PILOT — CRON (production must use secret)
# -----------------------------------------------------------------------------
REQUIRE_CRON_SECRET=true
CRON_SECRET=

# -----------------------------------------------------------------------------
# OPTIONAL — AI (at least one recommended for pilot)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# AI_ANALYSIS_URL=  (defaults to app URL + /api/ai/analyze-image)
# ANTHROPIC_API_KEY=  GOOGLE_AI_API_KEY=  GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL — BILLING (Stripe)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL — PUSH (FCM / APNS)
# -----------------------------------------------------------------------------
# FCM_PROJECT_ID=  FCM_CLIENT_EMAIL=  FCM_PRIVATE_KEY=
# APNS_KEY=  APNS_KEY_ID=  APNS_TEAM_ID=  APNS_BUNDLE_ID=

# -----------------------------------------------------------------------------
# MUST BE FALSE / UNSET IN PROD — do not set or set to false
# -----------------------------------------------------------------------------
# DEBUG_AUTH=
# DEBUG_DIAG=
# ENABLE_DIAG_ROUTES=
# If you must enable debug on one host only: ALLOW_DEBUG_HOSTS=internal.example.com
