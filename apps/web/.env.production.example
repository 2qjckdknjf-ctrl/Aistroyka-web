# Production — copy to .env.production (not loaded by Next.js; use for reference or inject into Wrangler).
# Set these in Cloudflare Dashboard → Workers → aistroyka-web-production → Settings → Variables.
# Do not commit real values.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=
# Optional: comma-separated emails allowed to access /admin/system (PL1 observability). Server-side only.
# ADMIN_EMAILS=
