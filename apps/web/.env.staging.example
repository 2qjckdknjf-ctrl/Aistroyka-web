# =============================================================================
# STAGING — set in Cloudflare Dashboard → Workers → staging → Variables
# =============================================================================

# REQUIRED FOR PILOT
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=https://staging.aistroyka.ai
SUPABASE_SERVICE_ROLE_KEY=
NODE_ENV=production
REQUIRE_CRON_SECRET=true
CRON_SECRET=

# OPTIONAL
OPENAI_API_KEY=

# MUST BE FALSE IN PROD — for staging, optional: ALLOW_DEBUG_HOSTS=staging.aistroyka.ai
# DEBUG_AUTH=  DEBUG_DIAG=  ENABLE_DIAG_ROUTES=
