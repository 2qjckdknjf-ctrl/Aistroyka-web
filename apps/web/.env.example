# =============================================================================
# AISTROYKA — Environment variables (copy to .env.local for local dev)
# =============================================================================
# See docs/release-hardening/ENVIRONMENT_READINESS.md for validation and release rules.
# Run: node scripts/validate-release-env.mjs (from repo root) for readiness report.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED FOR WEB (auth, DB, app URL)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# REQUIRED FOR JOBS (cron-tick, job processing, admin operations)
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=

# Production: set REQUIRE_CRON_SECRET=true and set CRON_SECRET (see CRON_AND_JOBS_RUNBOOK.md)
# REQUIRE_CRON_SECRET=true
# CRON_SECRET=

# -----------------------------------------------------------------------------
# REQUIRED FOR AI (vision analysis, analyze-image route and job handlers)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# Optional: AI_ANALYSIS_URL (defaults to NEXT_PUBLIC_APP_URL + /api/ai/analyze-image)
# AI_ANALYSIS_URL=
# Optional providers: ANTHROPIC_API_KEY, GOOGLE_AI_API_KEY, GEMINI_API_KEY

# -----------------------------------------------------------------------------
# REQUIRED FOR BILLING (Stripe checkout, portal, webhooks)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# REQUIRED FOR PUSH (FCM Android, APNS iOS)
# -----------------------------------------------------------------------------
# FCM_PROJECT_ID=
# FCM_CLIENT_EMAIL=
# FCM_PRIVATE_KEY=
# FCM_TOKEN_URI=
# APNS_KEY=
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=

# -----------------------------------------------------------------------------
# FORBIDDEN IN PRODUCTION — must be unset or false in prod
# -----------------------------------------------------------------------------
# DEBUG_AUTH=
# DEBUG_DIAG=
# ENABLE_DIAG_ROUTES=
# When ALLOW_DEBUG_HOSTS is set, debug/diag only allowed for listed hosts (comma-separated).
# ALLOW_DEBUG_HOSTS=

# -----------------------------------------------------------------------------
# OPTIONAL
# -----------------------------------------------------------------------------
# NODE_ENV=development
# AI_TRUSTED_IMAGE_HOSTS=  (comma-separated for AI image URL allow-list)
# MEDIA_FINALIZE_VERIFY_OBJECT=
# MEDIA_FINALIZE_VERIFY_STRICT=
# OPS_EVENTS_RETENTION_DAYS=
# SYNC_MIN_RETAINED_CURSOR=
# SCIM_ENABLED=
# SCIM_TOKEN=
