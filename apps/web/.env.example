# Supabase (required for auth + DB + storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL (used for auth callbacks, links; required for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only (do not expose to client; set in Vercel/CI as env vars)
# SUPABASE_SERVICE_ROLE_KEY=
# OPENAI_API_KEY=
# AI_ANALYSIS_URL= (if different from in-app)
# Stripe: STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
# FCM (push): FCM_PROJECT_ID, FCM_CLIENT_EMAIL, FCM_PRIVATE_KEY (PEM)

# Unified AI: in-app endpoint (set to NEXT_PUBLIC_APP_URL + /api/ai/analyze-image in dev)
AI_ANALYSIS_URL=http://localhost:3000/api/ai/analyze-image

# OpenAI Vision (required for in-app AI)
OPENAI_API_KEY=sk-your-openai-key
# Optional: model (default gpt-4o), timeout ms (default 85000, clamped 30k–120k), retries on 5xx (default 1)
# OPENAI_VISION_MODEL=gpt-4o
# OPENAI_VISION_TIMEOUT_MS=85000
# OPENAI_RETRY_ON_5XX=1
# Worker (runOneJob): AI_REQUEST_TIMEOUT_MS (default 90000), AI_RETRY_ATTEMPTS (default 3)
