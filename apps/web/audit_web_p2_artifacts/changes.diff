+"use client";
+
+import { useEffect } from "react";
+import { ErrorState } from "@/components/ui/ErrorState";
+
+export default function GovernanceError({
+  error,
+  reset,
+}: {
+  error: Error & { digest?: string };
+  reset: () => void;
+}) {
+  useEffect(() => {
+    console.error("Governance dashboard error:", error);
+  }, [error]);
+
+  return (
