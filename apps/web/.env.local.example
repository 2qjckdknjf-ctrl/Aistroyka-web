# Copy to .env.local and fill in from Supabase Dashboard (Project Settings → API).
# Do not commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: service role key. If set, bucket "media" is created automatically on first upload.
# SUPABASE_SERVICE_ROLE_KEY=
# Canonical app URL (for redirects, auth redirectTo). Production: set to https://aistroyka.ai
NEXT_PUBLIC_APP_URL=http://localhost:3000
