+    <QueryClientProvider client={client}>
+      {children}
+      {IS_DEV_OR_STAGING && (
+        <ReactQueryDevtools initialIsOpen={false} buttonPosition="bottom-left" />
+      )}
+    </QueryClientProvider>
+  );
+}
