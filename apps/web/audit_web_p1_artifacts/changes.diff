+  history: AnalysisSnapshot[];
+}) {
+  if (history.length === 0) {
+    return (
+      <div className="rounded-lg border border-aistroyka-border-subtle bg-aistroyka-surface-raised p-4 text-sm text-aistroyka-text-secondary sm:p-6">
