+[[env.staging.services]]
+binding = "WORKER_SELF_REFERENCE"
+service = "aistroyka-web-staging"
+
+# ----------------------------------------
+# [env.production] — production Worker
+# ----------------------------------------
+[env.production]
+name = "aistroyka-web-production"
+
+[env.production.assets]
+directory = ".open-next/assets"
+binding = "ASSETS"
+
+# Домен aistroyka.ai: если деплой выдаёт "assigned to another worker", в Dashboard снимите маршрут с другого Worker и задеплоййте снова.
+[[env.production.routes]]
+pattern = "aistroyka.ai"
+zone_name = "aistroyka.ai"
+
+[[env.production.routes]]
+pattern = "aistroyka.ai/*"
+zone_name = "aistroyka.ai"
+
+[[env.production.routes]]
+pattern = "www.aistroyka.ai"
+zone_name = "aistroyka.ai"
+
+[[env.production.routes]]
+pattern = "www.aistroyka.ai/*"
+zone_name = "aistroyka.ai"
+
+[[env.production.services]]
+binding = "WORKER_SELF_REFERENCE"
+service = "aistroyka-web-production"
