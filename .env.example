# =============================================================================
# AISTROYKA — root .env.example (minimal; see apps/web/.env.example for full list)
# =============================================================================
# Copy to .env.local or use Cloudflare Workers Variables for deploy.

# REQUIRED FOR PILOT
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=http://localhost:3000
SUPABASE_SERVICE_ROLE_KEY=
NODE_ENV=development

# CRON — production: REQUIRE_CRON_SECRET=true, CRON_SECRET=<secret>
# REQUIRE_CRON_SECRET=
# CRON_SECRET=

# OPTIONAL: OPENAI_API_KEY=  STRIPE_*  FCM_*  APNS_*
# FORBIDDEN IN PROD: DEBUG_AUTH  DEBUG_DIAG  ENABLE_DIAG_ROUTES
